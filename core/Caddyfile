# Homelab Caddyfile#
# TLS strategy: Tailscale-issued certificates via caddy-tailscale (tsnet).
# Each service registers as its own Tailscale node and gets a valid HTTPS cert
# automatically. No manual cert management or trust store required on Tailscale
# devices.
#
# TS_DOMAIN is set in .env (e.g. magic-dns.ts.net).
# TS_AUTHKEY must be a reusable pre-authorized auth key with tag:homelab.

{
	email {$ACME_EMAIL}

	tailscale {
		auth_key {$TS_AUTHKEY}
		webui true
		advertise_tags tag:homelab
	}
}

(common) {
	tls {
		get_certificate tailscale
	}
	encode gzip zstd

	header {
		# HSTS is fine for tailnet-only HTTPS, but `preload` is not meaningful here
		# because ts.net/internal domains are not preload-list candidates.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}

(common_proxy) {
	reverse_proxy {args[0]}
}

# ── Core ─────────────────────────────────────────────────────────────────────

adguard.{$TS_DOMAIN} {
	bind tailscale/adguard
	import common
	import common_proxy adguard:3000
}

home.{$TS_DOMAIN} {
	bind tailscale/home
	import common
	import common_proxy homepage:3000
}

