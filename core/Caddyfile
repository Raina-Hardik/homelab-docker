# Homelab Caddyfile
#
# All site addresses use {$TS_DOMAIN} which Caddy expands from the TS_DOMAIN
# environment variable at startup. Set TS_DOMAIN in your .env file.
#
# TLS strategy: "tls internal" — Caddy acts as its own CA and issues self-signed certs.
# This works great for Tailscale-only access. To trust the cert on your devices, export
# the Caddy root CA from /data/caddy/pki/authorities/local/root.crt and add it to your
# OS/browser trust store.
#
# If you have a real public domain with DNS pointing to your server, replace
# "tls internal" with "tls {$ACME_EMAIL}" to use Let's Encrypt.
{
	email {$ACME_EMAIL}

	tailscale {
		auth_key {$TS_AUTHKEY}
	}
}

(common) {
	tls {
		get_certificate tailscale
	}
	encode gzip zstd

	header {
		# HSTS is fine for tailnet-only HTTPS, but `preload` is not meaningful here
		# because ts.net/internal domains are not preload-list candidates.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}

(common_proxy) {
	reverse_proxy {args[0]}
}

# ── Core ─────────────────────────────────────────────────────────────────────

adguard.{$TS_DOMAIN} {
	bind tailscale/adguard
	import common
	import common_proxy adguard:3000
}

# ── Media ─────────────────────────────────────────────────────────────────────

jellyfin.{$TS_DOMAIN} {
	bind tailscale/jellyfin
	import common
	import common_proxy jellyfin:8096
}

sonarr.{$TS_DOMAIN} {
	bind tailscale/sonarr
	import common
	import common_proxy sonarr:8989
}

radarr.{$TS_DOMAIN} {
	bind tailscale/radarr
	import common
	import common_proxy radarr:7878
}

prowlarr.{$TS_DOMAIN} {
	bind tailscale/prowlarr
	import common
	import common_proxy prowlarr:9696
}

pocketid.{$TS_DOMAIN} {
	bind tailscale/pocket-id
	import common
	import common_proxy pocket-id:1411
}

# qBittorrent traffic exits through Gluetun — proxy via the gluetun container
qbit.{$TS_DOMAIN} {
	bind tailscale/qbit
	import common
	import common_proxy gluetun:8080
}

# ── Cloud ─────────────────────────────────────────────────────────────────────

immich.{$TS_DOMAIN} {
	bind tailscale/immich
	import common
	import common_proxy immich-server:2283
}

nextcloud.{$TS_DOMAIN} {
	bind tailscale/nextcloud
	import common
	redir /.well-known/carddav /remote.php/dav/ 301
	redir /.well-known/caldav /remote.php/dav/ 301
	import common_proxy nextcloud:80
}

