nextcloud.{$TS_DOMAIN} {
	bind tailscale/nextcloud
	import common
	redir /.well-known/carddav /remote.php/dav/ 301
	redir /.well-known/caldav /remote.php/dav/ 301
	import common_proxy nextcloud:80
}

