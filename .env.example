# ============================================================
# SYSTEM
# ============================================================

# Timezone (e.g. Europe/Amsterdam, America/New_York, Asia/Kolkata)
TZ=

# UID and GID of the user running the stack — avoids permission issues on host mounts
# Run: id -u && id -g
PUID=
PGID=

# ============================================================
# DOMAINS
# ============================================================

# Your Tailscale machine hostname (e.g. myserver.tail1234.ts.net)
TS_DOMAIN=

# Optional: local domain if you have internal DNS (e.g. home.internal)
LOCAL_DOMAIN=

# ============================================================
# VPN — Gluetun / ProtonVPN (media stack)
# ============================================================

VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=openvpn

# ProtonVPN OpenVPN credentials (NOT your account login — use the credentials at
# https://account.proton.me/u/0/vpn/OpenVpnIKEv2)
OPENVPN_USER=
OPENVPN_PASSWORD=

# ============================================================
# IMMICH (cloud stack)
# ============================================================

IMMICH_DB_PASSWORD=
IMMICH_REDIS_PASSWORD=

# ============================================================
# NEXTCLOUD (cloud stack)
# ============================================================

NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=

NEXTCLOUD_MYSQL_ROOT_PASSWORD=
NEXTCLOUD_MYSQL_PASSWORD=
NEXTCLOUD_MYSQL_DATABASE=nextcloud
NEXTCLOUD_MYSQL_USER=nextcloud

# ============================================================
# AUTHENTIK (auth stack)
# ============================================================

# Generate with: openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=

AUTHENTIK_POSTGRES_PASSWORD=
AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_DB=authentik

# ============================================================
# GITHUB ACTIONS RUNNER (dev stack)
# ============================================================

# Personal access token with repo scope, or a fine-grained token with Actions write
GITHUB_RUNNER_TOKEN=

# Full repo URL the runner registers to (e.g. https://github.com/username/reponame)
GITHUB_RUNNER_REPO=

# Human-readable name shown in GitHub Actions UI
GITHUB_RUNNER_NAME=homelab-runner

# ============================================================
# VAULTWARDEN (extras stack — opt-in)
# ============================================================

# Leave blank to disable admin panel, or set a strong token
VAULTWARDEN_ADMIN_TOKEN=

# ============================================================
# N8N (extras stack — opt-in)
# ============================================================

N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Encryption key for stored credentials — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=
