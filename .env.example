# ============================================================
# SYSTEM
# ============================================================

# Timezone (e.g. Europe/Amsterdam, America/New_York, Asia/Kolkata)
TZ=

# UID and GID of the user running the stack — avoids permission issues on host mounts
# Run: id -u && id -g
PUID=
PGID=

# Optional override for host bind-mount root. Defaults to /mnt/docker when unset.
# Useful on laptops/dev boxes where /mnt/docker may require root permissions.
# Example: HOST_MOUNT_ROOT=/home/your-user/homelab-data
HOST_MOUNT_ROOT=

# Optional AdGuard DNS host port overrides. Keep 53/53 in production if available.
# On dev laptops, 53 is often occupied by systemd-resolved; set both to 5353.
ADGUARD_DNS_PORT_TCP=53
ADGUARD_DNS_PORT_UDP=53

# ============================================================
# DOMAINS
# ============================================================

# Email used by Caddy for Let's Encrypt (only needed if using "tls {$ACME_EMAIL}" instead of "tls internal")
ACME_EMAIL=

# Your Tailscale tailnet domain (e.g. tail1234.ts.net).
# Do NOT include your machine name here (e.g. NOT myserver.tail1234.ts.net).
# Find this in your Tailscale Admin Console under Settings > DNS
TS_DOMAIN=

# Tailscale OAuth Client Secret (required for caddy-tailscale plugin)
# Create at https://login.tailscale.com/admin/settings/oauth
# Recommended scopes: devices:write
TS_AUTHKEY=

# Optional Tailscale tags for caddy-tailscale (comma-separated if multiple).
# Defaults to tag:homelab when unset.
TS_TAG=tag:homelab

# Optional: local domain if you have internal DNS (e.g. home.internal)
LOCAL_DOMAIN=

# ============================================================
# VPN — Gluetun / ProtonVPN (media stack)
# ============================================================

VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=openvpn

# ProtonVPN OpenVPN credentials (NOT your account login — use the credentials at
# https://account.proton.me/u/0/vpn/OpenVpnIKEv2)
OPENVPN_USER=
OPENVPN_PASSWORD=

# ============================================================
# OBS — BESZEL (obs stack)
# ============================================================

# Public key generated by the Beszel Hub when you add a system.
# Leave blank on first boot. After booting, open Beszel UI → Add System →
# copy the key shown → paste it here → restart the beszel-agent container.
BESZEL_KEY=

# ============================================================
# IMMICH (cloud stack)
# ============================================================

IMMICH_DB_PASSWORD=

# Shared Redis password used by Immich + Nextcloud in the cloud stack
REDIS_PASSWORD=

# ============================================================
# NEXTCLOUD (cloud stack)
# ============================================================

NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=

NEXTCLOUD_MYSQL_ROOT_PASSWORD=
NEXTCLOUD_MYSQL_PASSWORD=
NEXTCLOUD_MYSQL_DATABASE=nextcloud
NEXTCLOUD_MYSQL_USER=nextcloud

# ============================================================
# POCKETID (auth stack)
# ============================================================

# Encryption key for PocketID - generate with `openssl rand -base64 60 | tr -d '\n'`
ENCRYPTION_KEY=

# ============================================================
# GITHUB ACTIONS RUNNER (dev stack)
# ============================================================

# Personal access token with repo scope, or a fine-grained token with Actions write
GITHUB_RUNNER_TOKEN=

# Full repo URL the runner registers to (e.g. https://github.com/username/reponame)
GITHUB_RUNNER_REPO=

# Human-readable name shown in GitHub Actions UI
GITHUB_RUNNER_NAME=homelab-runner

# ============================================================
# VAULTWARDEN (extras stack — opt-in)
# ============================================================

# Leave blank to disable admin panel, or set a strong token
VAULTWARDEN_ADMIN_TOKEN=

# ============================================================
# N8N (extras stack — opt-in)
# ============================================================

N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Encryption key for stored credentials — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=
